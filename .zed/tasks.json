[
  {
    "label": "[WINDOWS] compile all",
    "command": "powershell",
    "args": [
      "-NoProfile",
      "-ExecutionPolicy",
      "Bypass",
      "-File",
      "scripts/build-release-artifacts.ps1",
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always",
    "allow_concurrent_runs": false,
    "use_new_terminal": false,
  },
]
